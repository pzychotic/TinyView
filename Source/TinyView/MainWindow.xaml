<Window x:Class="TinyView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:TinyView"
        xmlns:behaviors="clr-namespace:TinyView.Behaviors"
        SnapsToDevicePixels="True" UseLayoutRounding="True"
        Title="{Binding WindowTitle, FallbackValue='TinyView'}"
        Height="600" Width="800">

    <!-- Show wait cursor while a file is loading -->
    <Window.Style>
        <Style TargetType="Window">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Cursor" Value="Wait" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <!-- Keyboard shortcuts -->
    <Window.InputBindings>
        <!-- Ctrl + 'O' for Open -->
        <KeyBinding Command="{Binding OpenCommand}" Key="O" Modifiers="Control" />

        <!-- Ctrl + '+' for Zoom in (main keyboard and numpad) -->
        <KeyBinding Command="{Binding ZoomInCommand}" Key="OemPlus" Modifiers="Control" />
        <KeyBinding Command="{Binding ZoomInCommand}" Key="Add" Modifiers="Control" />

        <!-- Ctrl + '-' for Zoom out (main keyboard and numpad) -->
        <KeyBinding Command="{Binding ZoomOutCommand}" Key="OemMinus" Modifiers="Control" />
        <KeyBinding Command="{Binding ZoomOutCommand}" Key="Subtract" Modifiers="Control" />

        <!-- Ctrl + '*' for Zoom reset (numpad) -->
        <KeyBinding Command="{Binding ZoomResetCommand}" Key="Multiply" Modifiers="Control" />

        <!-- S for region selection toggle -->
        <KeyBinding Command="{Binding ToggleRegionSelectCommand}" Key="S" />

        <!-- R for reset min/max -->
        <KeyBinding Command="{Binding ResetMinMaxCommand}" Key="R" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu HorizontalAlignment="Stretch" Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open" Command="{Binding OpenCommand}" InputGestureText="Ctrl+O">
                    <MenuItem.Icon>
                        <Image Source="/Resources/OpenFile.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGestureText="Alt+F4" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" Command="{Binding ZoomInCommand}" InputGestureText="Ctrl++">
                    <MenuItem.Icon>
                        <Image Source="/Resources/ZoomIn.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGestureText="Ctrl+-">
                    <MenuItem.Icon>
                        <Image Source="/Resources/ZoomOut.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Zoom _Reset" Command="{Binding ZoomResetCommand}" InputGestureText="Ctrl+*">
                    <MenuItem.Icon>
                        <Image Source="/Resources/ZoomReset.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Flip _Horizontal" IsCheckable="True" IsChecked="{Binding IsFlippedHorizontally, Mode=TwoWay}" IsEnabled="{Binding HasImage}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/FlipHorizontal.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Flip _Vertical" IsCheckable="True" IsChecked="{Binding IsFlippedVertically, Mode=TwoWay}" IsEnabled="{Binding HasImage}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/FlipVertical.png" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="?">
                <MenuItem Header="_About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <ToolBar Height="32" VerticalAlignment="Top" Grid.Row="1" >
            <Button Command="{Binding OpenCommand}" ToolTip="Open File (Ctrl+O)">
                <Image Source="/Resources/OpenFile.png" />
            </Button>
            <Separator />
            <Button Command="{Binding ZoomInCommand}" ToolTip="Zoom In (Ctrl++)">
                <Image Source="/Resources/ZoomIn.png" />
            </Button>
            <Button Command="{Binding ZoomOutCommand}" ToolTip="Zoom Out (Ctrl+-)">
                <Image Source="/Resources/ZoomOut.png" />
            </Button>
            <Button Command="{Binding ZoomResetCommand}" ToolTip="Reset Zoom (Ctrl+*)">
                <Image Source="/Resources/ZoomReset.png" />
            </Button>
            <Separator />
            <ToggleButton IsChecked="{Binding IsFlippedHorizontally}" IsEnabled="{Binding HasImage}" ToolTip="Flip Horizontal">
                <Image Source="/Resources/FlipHorizontal.png" />
            </ToggleButton>
            <ToggleButton IsChecked="{Binding IsFlippedVertically}" IsEnabled="{Binding HasImage}" ToolTip="Flip Vertical">
                <Image Source="/Resources/FlipVertical.png" />
            </ToggleButton>
            <Separator />
            <ComboBox x:Name="ComboBoxColorPalette" Width="80"
                      DisplayMemberPath="Name"
                      IsEnabled="{Binding HasImage}"
                      ItemsSource="{Binding Palettes}"
                      SelectedItem="{Binding SelectedPalette, Mode=TwoWay}"
                      ToolTip="Select color palette for visualization" />
            <Separator />
            <ToggleButton IsChecked="{Binding IsRegionSelectActive, Mode=TwoWay}"
                          IsEnabled="{Binding HasImage}"
                          ToolTip="Select region to set display min/max (S to toggle)"
                          Content="⬚" FontSize="16" Padding="2,0" />
            <TextBlock Text="Min:" VerticalAlignment="Center" Margin="4,0" />
            <TextBox Width="60" VerticalContentAlignment="Center"
                     Text="{Binding DisplayMin, StringFormat='{}{0:0.##}'}"
                     IsEnabled="{Binding HasImage}"
                     ToolTip="Display minimum value (commit with Enter or Tab)">
                <i:Interaction.Behaviors>
                    <behaviors:TextBoxCommitBehavior />
                </i:Interaction.Behaviors>
            </TextBox>
            <TextBlock Text="Max:" VerticalAlignment="Center" Margin="4,0" />
            <TextBox Width="60" VerticalContentAlignment="Center"
                     Text="{Binding DisplayMax, StringFormat='{}{0:0.##}'}"
                     IsEnabled="{Binding HasImage}"
                     ToolTip="Display maximum value (commit with Enter or Tab)">
                <i:Interaction.Behaviors>
                    <behaviors:TextBoxCommitBehavior />
                </i:Interaction.Behaviors>
            </TextBox>
            <Button Command="{Binding ResetMinMaxCommand}"
                    IsEnabled="{Binding HasImage}"
                    ToolTip="Reset to original min/max values (R)"
                    Content="↺" FontSize="16" Padding="2,0" />
        </ToolBar>

        <!-- ScrollViewer ensures image fits and can be scrolled if large -->
        <ScrollViewer x:Name="ImageScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Grid.Row="2">
            <i:Interaction.Behaviors>
                <behaviors:DropBehavior Command="{Binding DropCommand}" />
                <behaviors:MouseWheelZoomBehavior ZoomFactor="{Binding Zoom.Factor, Mode=TwoWay}" ZoomAnchor="{Binding Zoom.Anchor, Mode=TwoWay}" />
                <behaviors:ScrollViewerPanBehavior ResetNotifier="{Binding PanResetNotifier}" />
                <behaviors:OverpanBehavior IsEnabled="{Binding HasImage}" ResetNotifier="{Binding PanResetNotifier}" />
                <behaviors:ZoomCompensationBehavior ZoomFactor="{Binding Zoom.Factor}" ZoomAnchor="{Binding Zoom.Anchor, Mode=TwoWay}" />
            </i:Interaction.Behaviors>
            <Grid x:Name="ImageWrapper">
                <Grid x:Name="ImageContainer" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="{Binding ImageSource.PixelWidth, FallbackValue=0}"
                      Height="{Binding ImageSource.PixelHeight, FallbackValue=0}">
                    <Grid.LayoutTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="{Binding Zoom.Factor}" ScaleY="{Binding Zoom.Factor}" />
                            <ScaleTransform ScaleX="{Binding FlipScaleX}" ScaleY="{Binding FlipScaleY}" />
                        </TransformGroup>
                    </Grid.LayoutTransform>
                    <Image x:Name="PreviewImage" Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Source="{Binding ImageSource}">
                        <i:Interaction.Behaviors>
                            <behaviors:ImageHoverBehavior HoverCommand="{Binding HoverCommand}" LeaveCommand="{Binding LeaveHoverCommand}" />
                            <behaviors:RegionSelectBehavior IsActive="{Binding IsRegionSelectActive, Mode=TwoWay}"
                                                            SelectionCommand="{Binding ApplyRegionMinMaxCommand}" />
                        </i:Interaction.Behaviors>
                    </Image>
                </Grid>
            </Grid>
        </ScrollViewer>

        <StatusBar Grid.Row="3" Height="26">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>    <!-- left -->
                            <ColumnDefinition Width="*" />      <!-- center -->
                            <ColumnDefinition Width="Auto"/>    <!-- right -->
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- left -->
            <StatusBarItem Grid.Column="0" VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" ToolTip="Pixel position and raw value">
                    <Image Source="/Resources/Cursor.png" Width="16" Height="16" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding ValueText, FallbackValue='0,0: undefined'}" />
                </StackPanel>
            </StatusBarItem>

            <!-- center (empty filler) -->
            <StatusBarItem Grid.Column="1">
                <TextBlock />
            </StatusBarItem>

            <!-- right -->
            <StatusBarItem Grid.Column="2" VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" ToolTip="Current zoom factor">
                        <Image Source="/Resources/Zoom.png" Width="16" Height="16" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding Zoom.Factor, StringFormat='{}{0:0.%}', FallbackValue='100%'}" />
                    </StackPanel>

                    <Border Width="1" Height="16" Margin="4,0"
                            Background="{StaticResource {x:Static SystemColors.ControlDarkBrushKey}}" />

                    <StackPanel Orientation="Horizontal" ToolTip="Image size">
                        <Image Source="/Resources/ImageSize.png" Width="16" Height="16" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding ImageSizeText, FallbackValue='0x0'}" />
                    </StackPanel>

                    <Border Width="1" Height="16" Margin="4,0"
                            Background="{StaticResource {x:Static SystemColors.ControlDarkBrushKey}}" />

                    <StackPanel Orientation="Horizontal" ToolTip="Image value range (min..max)">
                        <Image Source="/Resources/ImageMinMax.png" Width="16" Height="16" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding ImageMinMaxText, FallbackValue='0..0'}" />
                    </StackPanel>

                    <Border Width="1" Height="16" Margin="4,0"
                            Background="{StaticResource {x:Static SystemColors.ControlDarkBrushKey}}" />

                    <TextBlock Text="{Binding ImageFormatText, FallbackValue='undefined'}" ToolTip="Image format" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
